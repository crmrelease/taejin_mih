# GitHub (used by mo-bot work-log push and PR scripts)
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_REPO=

# Slack (mo-bot socket-mode app)
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# JSONBin polling monitor (favorite-player board)
# - JSONBIN_BIN_ID: 24-hex bin id holding {"players":[...]} or [...]
# - JSONBIN_MASTER_KEY: X-Master-Key value (read access)
# - MONITOR_ALERT_TARGET: Slack user id (DM) or channel id (Cxxxx) to notify
# - MONITOR_INTERVAL_MS: poll interval; 300000 (5 min) keeps free tier within quota
# - MONITOR_PAGE_URL: public URL surfaced in alert
JSONBIN_BIN_ID=
JSONBIN_MASTER_KEY=
MONITOR_ALERT_TARGET=
MONITOR_INTERVAL_MS=300000
MONITOR_PAGE_URL=
