# GitHub (used by mo-bot work-log push and PR scripts)
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_REPO=

# Slack (mo-bot socket-mode app)
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# JSONBin polling monitor (favorite-player board)
# - JSONBIN_BIN_ID: 24-hex bin id holding {"players":[...]} or [...]
# - JSONBIN_MASTER_KEY: X-Master-Key value (read access)
# - MONITOR_ALERT_TARGET: Slack user id (DM) or channel id (Cxxxx) to notify
# - MONITOR_INTERVAL_MS: poll interval; 300000 (5 min) keeps free tier within quota
# - MONITOR_PAGE_URL: public URL surfaced in alert
JSONBIN_BIN_ID=
JSONBIN_MASTER_KEY=
MONITOR_ALERT_TARGET=
MONITOR_INTERVAL_MS=300000
MONITOR_PAGE_URL=

# Incident routing
# - MONITOR_ERROR_CHANNEL: Slack channel id (Cxxxx). Errors and recovery alerts go here.
#   If unset, falls back to MONITOR_ALERT_TARGET (DM).
# - MONITOR_OWNER_USER_ID: Slack user id of human owner — mentioned on incident
#   recovery and 10-minute timeout failures.
# - MONITOR_DEV_USER_ID: Slack user id of frontend developer — mentioned on
#   page-down failures (suggests frontend-side check).
# - MONITOR_INCIDENT_TIMEOUT_MS: time before declaring "self-heal failed". Default 600000 (10 min).
# - MONITOR_IMGBB_URL: imgbb endpoint to probe for service availability.
MONITOR_ERROR_CHANNEL=
MONITOR_OWNER_USER_ID=
MONITOR_DEV_USER_ID=
MONITOR_INCIDENT_TIMEOUT_MS=600000
MONITOR_IMGBB_URL=https://api.imgbb.com/1/upload
